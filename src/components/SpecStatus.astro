---
// src/components/SpecStatus.astro
export interface Props {
  status: 'stable' | 'draft' | 'deprecated';
  version?: string;
}
const { status, version } = Astro.props;

const labels = {
  stable: 'Stable',
  draft: 'Working Draft',
  deprecated: 'Deprecated',
};

const emojis = {
  stable: '✓',
  draft: '✎',
  deprecated: '⚠',
};
---

<span class="spec-status {status}" title={`Version ${version || 'current'}`}>
  {emojis[status]} {labels[status]}
  {version && <span class="version-badge">v{version}</span>}
</span>